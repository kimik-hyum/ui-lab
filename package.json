{
  "name": "ui-lab-monorepo",
  "private": true,
  "packageManager": "yarn@4.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace lab-shell dev",
    "dev:all": "yarn workspaces foreach -A --exclude ui-lab-monorepo --parallel --interlaced --verbose run dev",
    "dev:lab-shell": "yarn workspace lab-shell dev",
    "dev:next-lab": "yarn workspace next-lab dev",
    "dev:react-router-lab": "yarn workspace react-router-lab dev",
    "dev:sveltekit-lab": "yarn workspace sveltekit-lab dev",
    "dev:vue-lab": "yarn workspace vue-lab dev",
    "start:lab-shell": "yarn workspace lab-shell start",
    "start:next-lab": "yarn workspace next-lab start",
    "start:react-router-lab": "yarn workspace react-router-lab start",
    "start:sveltekit-lab": "yarn workspace sveltekit-lab preview",
    "start:vue-lab": "yarn workspace vue-lab preview",
    "serve:lab-shell": "yarn workspace lab-shell build && yarn workspace lab-shell start",
    "serve:next-lab": "yarn workspace next-lab build && yarn workspace next-lab start",
    "serve:react-router-lab": "yarn workspace react-router-lab build && yarn workspace react-router-lab preview",
    "serve:sveltekit-lab": "yarn workspace sveltekit-lab build && yarn workspace sveltekit-lab preview",
    "serve:vue-lab": "yarn workspace vue-lab build && yarn workspace vue-lab preview",
    "build": "yarn workspaces foreach -Apt run build",
    "build:lab-shell": "yarn workspace lab-shell build",
    "build:next-lab": "yarn workspace next-lab build",
    "build:react-router-lab": "yarn workspace react-router-lab build",
    "build:sveltekit-lab": "yarn workspace sveltekit-lab build",
    "build:vue-lab": "yarn workspace vue-lab build",
    "lint": "yarn workspaces foreach -Apt run lint",
    "lint:staged": "lint-staged",
    "generate:types:openapi": "node scripts/generate-openapi-types.mjs",
    "perf:lighthouse": "node scripts/lighthouse-compare.mjs",
    "perf:lighthouse:quick": "LH_RUNS=1 node scripts/lighthouse-compare.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/lab-shell/**/*.{js,jsx,ts,tsx}": [
      "sh -c 'cd apps/lab-shell && ../../node_modules/.bin/eslint --max-warnings=0 --no-warn-ignored --ignore-pattern \"app/front-feature/nextjs/rsc-vs-csc/**\" .'"
    ],
    "apps/next-lab/**/*.{js,jsx,ts,tsx}": [
      "sh -c 'cd apps/next-lab && ../../node_modules/.bin/eslint --max-warnings=0 --no-warn-ignored .'"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lighthouse": "^13.1.0",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "swagger2openapi": "^7.0.8",
    "typescript": "^5"
  }
}
