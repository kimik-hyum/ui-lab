{
  "name": "ui-lab-monorepo",
  "private": true,
  "packageManager": "yarn@4.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace lab-shell dev",
    "dev:lab-shell": "yarn workspace lab-shell dev",
    "dev:next-lab": "yarn workspace next-lab dev",
    "dev:sveltekit-lab": "yarn workspace sveltekit-lab dev",
    "build": "yarn workspaces foreach -Apt run build",
    "build:lab-shell": "yarn workspace lab-shell build",
    "lint": "yarn workspaces foreach -Apt run lint",
    "lint:staged": "lint-staged",
    "perf:lighthouse": "node scripts/lighthouse-compare.mjs",
    "perf:lighthouse:quick": "LH_RUNS=1 node scripts/lighthouse-compare.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/lab-shell/**/*.{js,jsx,ts,tsx}": [
      "sh -c 'cd apps/lab-shell && ../../node_modules/.bin/eslint --max-warnings=0 --no-warn-ignored --ignore-pattern \"app/front-feature/nextjs/rsc-vs-csc/**\" .'"
    ],
    "apps/next-lab/**/*.{js,jsx,ts,tsx}": [
      "sh -c 'cd apps/next-lab && ../../node_modules/.bin/eslint --max-warnings=0 --no-warn-ignored .'"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lighthouse": "^13.1.0",
    "lint-staged": "^16.4.0"
  }
}
